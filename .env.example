# Safe zero-cost mode (default)
USE_OPENAI=0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini-2024-07-18
OPENAI_TIMEOUT_SECONDS=20

# This reference application intentionally binds to loopback only.
HOST=127.0.0.1
PORT=8080

# Leave empty to use ./data. Tests always use a temporary directory.
CRM_DATA_DIR=
MAX_REQUEST_BYTES=16384
MAX_MESSAGE_CHARS=10000

# Raw inquiry text may contain personal data and is not stored by default.
STORE_RAW_MESSAGE=0
